        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "data = pd.read_csv(\"consumo_energetico.csv\")\n",
        "\n",
        "print(data)\n",
        "\n",
        "plt.plot(data[\"consumo_kwh\"])\n",
        "plt.title(\"Consumo energético\")\n",
        "plt.xlabel(\"Día\")\n",
        "plt.ylabel(\"kWh\")\n",
        "plt.show()\n",
        "\n",
        "from sklearn.linear_model import LinearRegression\n",
        "import numpy as np\n",
        "\n",
        "X = np.array(range(len(data))).reshape(-1,1)\n",
        "y = data[\"consumo_kwh\"]\n",
        "\n",
        "modelo = LinearRegression()\n",
        "modelo.fit(X,y)\n",
        "\n",
        "prediccion = modelo.predict([[12]])\n",
        "\n",
        "print(\"Consumo estimado futuro:\", prediccion)"
      ]
    }
